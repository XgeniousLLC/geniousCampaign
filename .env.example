# Copy this file to .env at the repo root and fill in values.
# Sprint 0/1 values are enough to run everything through Sprint 1 (npm run dev).
# Both apps/api (NestJS) and apps/web (Vite) read this single root .env.

# --- Sprint 0 ---

# Database / queue
# (Docker: DATABASE_URL/REDIS_URL are overridden in docker-compose.yml to
# point at the bundled postgres/redis containers — set POSTGRES_PASSWORD
# below instead. These two are only read directly for a non-Docker/manual
# setup — see DEPLOY.md.)
DATABASE_URL=postgresql://localhost:5432/geniuscampaign_dev
REDIS_URL=redis://localhost:6379

# Docker only — password for the bundled postgres container.
POSTGRES_PASSWORD=geniuscampaign

# Docker only — host-side ports (container-internal ports never change).
# Override any of these if the default is already in use on the host.
POSTGRES_PORT=5432
REDIS_PORT=6379
API_PORT=3000
WEB_PORT=8080

NODE_ENV=development
PORT=3000

# apps/web reads this to reach apps/api — baked in at build time (Vite),
# not read at runtime. For Docker, set this to whatever URL the BROWSER
# will use to reach the api container (not the Docker-internal hostname).
VITE_API_BASE_URL=http://localhost:3000

# Auth (JWT) — generate with `openssl rand -hex 32`
JWT_SECRET=

# --- Sprint 1 ---

# AWS SES — AWS_ACCESS_KEY_ID/SECRET_ACCESS_KEY are read from the standard AWS
# SDK credential chain (env vars, ~/.aws/credentials, or an IAM role) rather
# than a custom var name; set them if not already available via that chain.
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_CONFIGURATION_SET=
SES_FROM_EMAIL=

# Cloudflare R2
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_PUBLIC_BASE_URL=

# Tracking
TRACKING_DOMAIN=track.yourdomain.com
TRACKING_SIGNING_SECRET=

# --- Sprint 3 ---

# Gmail Workspace sending
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=
ADMIN_APP_URL=
TOKEN_ENCRYPTION_KEY=
GMAIL_DEFAULT_DAILY_LIMIT=300

# Email verification
REOON_API_KEY=
NEVERBOUNCE_API_KEY=

# Outbound webhooks
OUTBOUND_WEBHOOK_HMAC_SECRET=

# --- Sprint 4 ---

# Slack notifications
SLACK_WEBHOOK_URL=

# GC-059 AI-assisted template copy — multi-provider, pick one or both.
# LLM_PROVIDER selects the default: "openai" | "deepseek"
LLM_PROVIDER=openai
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
